{
  "manifest_version": 3,
  "name": "Bonobo",
  "version": "0.1.0",
  "description": "Bonobo is a better userscript manager for Chromium.",
  "permissions": [
    "userScripts"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "minimum_chrome_version": "120",

  "icons": {
   "16": "icons/bonobo_16x16.png",
   "32": "icons/bonobo_32x32.png",
   "48": "icons/bonobo_48x48.png",
   "128": "icons/bonobo_128x128.png"
 },

 "background": {
    "service_worker": "worker.js"
  },

  "action": {}
}
